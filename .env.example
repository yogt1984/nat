# NAT Environment Variables
# Copy this file to .env and fill in your values

# =============================================================================
# DOCKER / CLOUD
# =============================================================================
# Domain for Caddy HTTPS (leave as localhost for local dev)
DOMAIN=localhost
ACME_EMAIL=admin@example.com

# =============================================================================
# POSTGRESQL
# =============================================================================
POSTGRES_PASSWORD=changeme

# =============================================================================
# GRAFANA
# =============================================================================
GRAFANA_PASSWORD=changeme
# Set to false on production to require login
GRAFANA_ANON=true

# =============================================================================
# REDIS
# =============================================================================
REDIS_URL=redis://127.0.0.1:6379

# =============================================================================
# API SERVER
# =============================================================================
NAT_API_HOST=0.0.0.0
NAT_API_PORT=3000

# =============================================================================
# TELEGRAM ALERTS
# =============================================================================
# Get these from @BotFather on Telegram
# Run: ./scripts/setup_telegram.sh for interactive setup

TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# =============================================================================
# ALERTS CONFIGURATION
# =============================================================================
# Thresholds for alert triggering (optional)

ALERT_WHALE_ACC_ZSCORE=2.0
ALERT_WHALE_DIST_ZSCORE=-2.0
ALERT_ENTROPY_LOW=0.5
ALERT_REGIME_CLARITY=0.6
ALERT_COOLDOWN_MS=300000
