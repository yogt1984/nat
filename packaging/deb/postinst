#!/bin/sh
# postinst — finalize the nat install.
set -e

# Symlink the CLI onto PATH. The real file stays under /usr/lib/nat; nat_paths
# detects "installed" mode (no .git / rust/Cargo.toml there) and resolves config
# from /etc/nat and data from $NAT_HOME or ~/.local/share/nat — no symlink hacks.
ln -sf /usr/lib/nat/nat /usr/bin/nat
chmod +x /usr/lib/nat/nat 2>/dev/null || true
chmod +x /usr/lib/nat/rust/target/release/* 2>/dev/null || true

echo "nat installed. Run 'nat help', then 'nat config paths' to see resolved locations."
echo "Override data location with NAT_HOME=/var/lib/nat (system) or it defaults to ~/.local/share/nat."
exit 0
