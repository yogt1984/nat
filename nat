# ── Main ─────────────────────────────────────────────────────────────────────

def main():
    parser = build_parser()
    args = parser.parse_args()

    if args.command is None or args.command == 'help':
        cmd_help()
        return

    if hasattr(args, 'func'):
        print()
        args.func(args)
        print()
    else:
        parser.print_help()


if __name__ == "__main__":
    main()
