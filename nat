#!/usr/bin/env python3
"""nat — unified NAT research terminal (thin entry shim).

All command groups live in scripts/cli/*.py; cli/app.py assembles the parser and
dispatch. This file just puts scripts/ on the import path and runs cli.app.main().
Handlers and build_parser are re-exported below so the test suite (which loads
this file as a module and references nat.build_parser / nat.cmd_*) keeps working.
"""

import sys
from pathlib import Path

sys.path.insert(0, str(Path(__file__).resolve().parent / "scripts"))

from cli.app import *  # noqa: E402,F401,F403  (re-export build_parser/main/cmd_* for tests)
from cli.app import main  # noqa: E402

if __name__ == "__main__":
    sys.exit(main())
