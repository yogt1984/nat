    """The sole human gate: APPROVAL_PENDING → LIVE (requires --confirm)."""
    lc = _lifecycle(args)
    try:
        sig = lc.get_signal(args.signal_id)
        if sig is None:
            print(f"  {R}Not found:{W} {args.signal_id}")
            return 1
        print(f"\n  {BOLD}APPROVE → LIVE{W}: {args.signal_id}")
