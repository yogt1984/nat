def _latest_feature_day(args):
    """Resolve the most recent YYYY-MM-DD dir under the feature data dir."""
    dd = Path(_data(args))
    days = sorted(d.name for d in dd.glob('*') if d.is_dir() and d.name[:4].isdigit())
    return days[-1] if days else None


