FIFTEEN_MIN = 15 * 60


def _today_data(args):
    """Resolve data dir: explicit --data, or today's date directory."""
    d = getattr(args, 'data', None)
    if d:
        return d
    today = datetime.now().strftime("%Y-%m-%d")
